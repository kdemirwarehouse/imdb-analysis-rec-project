data/raw/*
data/processed/*
data/external/*
!data/raw/.gitkeep
!data/processed/.gitkeep
!data/external/.gitkeep

models/*
!models/.gitkeep

reports/figures/*.png
reports/figures/*.html
reports/figures/*.svg

